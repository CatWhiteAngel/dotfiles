[user]
	name = CatWhiteAngel
	email = 30596187+CatWhiteAngel@users.noreply.github.com
	signingkey = C8DD1251A555016E

[init]
	defaultBranch = main

[core]
	editor = vim
	autocrlf = input
	pager = less -FRX

[color]
	ui = auto

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	followTags = true

[fetch]
	prune = true
	pruneTags = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[rerere]
	enabled = true

[rebase]
	autosquash = true
	autostash = true

[branch]
	sort = -committerdate

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	cm = commit -m
	amend = commit --amend --no-edit
	unstage = restore --staged
	last = log -1 HEAD --stat
	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'
	uncommit = reset --soft HEAD~1
	aliases = config --get-regexp '^alias\\.'
[gpg]
	program = /usr/bin/gpg
[commit]
	gpgsign = true
[tag]
	gpgsign = true
